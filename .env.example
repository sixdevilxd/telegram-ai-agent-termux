# ====== WAJIB DIISI ======
# Token bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=

# API key untuk LLM
# Dapatkan gratis dari: https://build.nvidia.com
OPENAI_API_KEY=nvapi-xxxxxxxx

# ====== OPSIONAL (boleh dibiarkan default) ======

# Provider & Model Utama (Sekarang default ke NVIDIA NIM / DeepSeek)
PROVIDER=openai
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=deepseek-ai/deepseek-v4-pro

# Provider alternatif (AgentRouter / Anthropic)
# AGENTROUTER_API_KEY=
# AGENTROUTER_BASE_URL=https://agentrouter.org/v1
# MODEL=claude-opus-4-6

# Kepribadian AI. KOSONGKAN baris ini agar memakai persona default "CIPHER"
# (research agent crypto + coding vibes). Isi hanya jika ingin menimpa.
# SYSTEM_PROMPT=

# Kreativitas jawaban (0.0 - 2.0)
TEMPERATURE=0.7

# Maksimum token jawaban (DeepSeek V4 bisa hingga 16384)
MAX_TOKENS=16384

# Reasoning mendalam (extended thinking) — analisa jauh lebih kuat & teliti.
# true/false. REASONING_BUDGET = jatah token berpikir (min 1024).
# Matikan (false) untuk NVIDIA DeepSeek karena belum didukung API-nya.
REASONING=false
REASONING_BUDGET=8000

# Jumlah pasang pesan yang diingat per chat
MAX_HISTORY=12

# Batasi siapa yang boleh memakai bot (pisahkan koma). Kosongkan = semua boleh.
# Cari id kamu dengan perintah /whoami setelah bot jalan.
ALLOWED_USERS=
