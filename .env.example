# ====== WAJIB DIISI ======
# Token bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=

# API key dari https://agentrouter.org/console/token
AGENTROUTER_API_KEY=

# ====== OPSIONAL (boleh dibiarkan default) ======
# Endpoint AgentRouter (route Anthropic /messages dipakai otomatis)
AGENTROUTER_BASE_URL=https://agentrouter.org/v1

# Model. AgentRouter umumnya hanya mengizinkan claude-opus-4-6 di sebagian plan.
# Cek model yang diizinkan di dashboard AgentRouter.
MODEL=claude-opus-4-6

# ====== PROVIDER CADANGAN (opsional tapi SANGAT disarankan) ======
# Kalau AgentRouter membalas "content-blocked", bot otomatis pindah ke sini.
# Pakai layanan OpenAI-compatible mana saja (OpenRouter / Groq / OpenAI / dll).
# Contoh OpenRouter (banyak model murah/gratis): daftar di https://openrouter.ai/keys
PROVIDER=agentrouter
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini

# Kepribadian AI. KOSONGKAN baris ini agar memakai persona default "CIPHER"
# (research agent crypto + coding vibes). Isi hanya jika ingin menimpa.
# SYSTEM_PROMPT=

# Kreativitas jawaban (0.0 - 2.0)
TEMPERATURE=0.7

# Maksimum token jawaban
MAX_TOKENS=4096

# Jumlah pasang pesan yang diingat per chat
MAX_HISTORY=12

# Batasi siapa yang boleh memakai bot (pisahkan koma). Kosongkan = semua boleh.
# Cari id kamu dengan perintah /whoami setelah bot jalan.
ALLOWED_USERS=
