# ====== WAJIB DIISI ======
# Token bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=

# API key dari https://agentrouter.org/console/token
AGENTROUTER_API_KEY=

# ====== OPSIONAL (boleh dibiarkan default) ======
# Endpoint AgentRouter (OpenAI-compatible)
AGENTROUTER_BASE_URL=https://agentrouter.org/v1

# Model default. Contoh: gpt-5, claude-sonnet-4-5-20250929, deepseek-v3
MODEL=gpt-5

# Kepribadian / instruksi sistem untuk AI
SYSTEM_PROMPT=Kamu adalah asisten AI yang ramah, cerdas, dan membantu. Jawab dengan bahasa yang sama seperti pengguna.

# Kreativitas jawaban (0.0 - 2.0)
TEMPERATURE=0.7

# Jumlah pasang pesan yang diingat per chat
MAX_HISTORY=12

# Batasi siapa yang boleh memakai bot (pisahkan koma). Kosongkan = semua boleh.
# Cari id kamu dengan perintah /whoami setelah bot jalan.
ALLOWED_USERS=
